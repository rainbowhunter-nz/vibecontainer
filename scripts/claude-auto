#!/usr/bin/env bash
set -euo pipefail

if [ "$(id -u)" -eq 0 ]; then
  echo "Refusing to run Claude Code as root." >&2
  exit 1
fi

if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  if [ -d "$git_root/workspace" ]; then
    cd "$git_root/workspace"
  fi
fi

exec claude --permission-mode auto "$@"
