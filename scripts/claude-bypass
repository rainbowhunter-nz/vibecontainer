#!/usr/bin/env bash
set -euo pipefail

if [ "$(id -u)" -eq 0 ]; then
  echo "Refusing to run Claude Code bypass mode as root." >&2
  exit 1
fi

if [ ! -d /home/vscode/.claude ]; then
  echo "Expected /home/vscode/.claude to exist. Check the devcontainer mount." >&2
  exit 1
fi

# Prefer the workspace source folder when launched from elsewhere in the repo.
if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  if [ -d "$git_root/workspace" ]; then
    cd "$git_root/workspace"
  fi
fi

exec claude --dangerously-skip-permissions "$@"
